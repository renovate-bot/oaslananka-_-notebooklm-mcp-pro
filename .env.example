# notebooklm-mcp-pro - Environment Variables Reference
# Copy this file to .env and fill in your values.

# Transport
# stdio: local MCP clients; http: remote MCP and OpenAPI clients.
NLM_MCP_TRANSPORT=stdio

# HTTP server
NLM_MCP_HTTP_HOST=0.0.0.0
NLM_MCP_HTTP_PORT=8080
NLM_MCP_HTTP_PATH=/mcp
NLM_MCP_STATELESS_HTTP=true
# Public URL used in OpenAPI schemas, plugin manifests, and OAuth redirects.
# NLM_MCP_BASE_URL=https://your-server.example.com

# Authentication
# none: local/trusted only; token: bearer token; github-oauth: GitHub OAuth login.
NLM_MCP_AUTH_MODE=none
# Required when auth_mode=token. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# NLM_MCP_BEARER_TOKEN=your-secure-token-here
NLM_MCP_TOKEN_QUERY_PARAM=token

# GitHub OAuth
# Required when auth_mode=github-oauth.
# NLM_MCP_GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# NLM_MCP_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
NLM_MCP_GITHUB_REDIRECT_PATH=/auth/callback
NLM_MCP_OAUTH_REQUIRED_SCOPES=read:user,user:email
# Comma-separated GitHub usernames allowed to authenticate. Empty means any GitHub user.
# NLM_MCP_OAUTH_ALLOWED_USERS=oaslananka,collaborator2

# NotebookLM authentication
# Option 1: auth file path. Run notebooklm-py login to create it.
NLM_MCP_NOTEBOOKLM_AUTH_FILE=~/.config/nlm-mcp/notebooklm_auth.json
# Option 2: inline JSON for Docker/cloud environments.
# NLM_MCP_NOTEBOOKLM_AUTH_JSON={"cookies":[]}

# Language
NLM_MCP_DEFAULT_LANGUAGE=en

# Data storage
NLM_MCP_DATA_DIR=~/.local/share/nlm-mcp
# SQLite session DB. {DATA_DIR} is replaced at runtime.
# NLM_MCP_SESSION_DB=sqlite+aiosqlite:///{DATA_DIR}/sessions.db
# NLM_MCP_ENCRYPTION_KEY=
# NLM_MCP_REDIS_URL=

# Rate limiting
NLM_MCP_RATE_LIMIT_ENABLED=true
NLM_MCP_RATE_LIMIT_PER_USER_RPM=60
NLM_MCP_RATE_LIMIT_GENERATE_RPM=10

# Logging
NLM_MCP_LOG_FORMAT=json
NLM_MCP_LOG_LEVEL=INFO
# NLM_MCP_AUDIT_LOG_PATH={DATA_DIR}/audit.log

# Safety
NLM_MCP_DESTRUCTIVE_REQUIRES_CONFIRM=true

# Artifact generation polling
NLM_MCP_DEFAULT_POLL_INTERVAL_SEC=15
NLM_MCP_DEFAULT_POLL_TIMEOUT_SEC=600
