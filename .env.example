# --- Transport ---
NLM_MCP_TRANSPORT=stdio
NLM_MCP_HTTP_HOST=0.0.0.0
NLM_MCP_HTTP_PORT=8080
NLM_MCP_HTTP_PATH=/mcp
NLM_MCP_BASE_URL=
NLM_MCP_STATELESS_HTTP=true

# --- Auth ---
NLM_MCP_AUTH_MODE=none
NLM_MCP_BEARER_TOKEN=
NLM_MCP_TOKEN_QUERY_PARAM=token
NLM_MCP_GITHUB_CLIENT_ID=
NLM_MCP_GITHUB_CLIENT_SECRET=
NLM_MCP_GITHUB_REDIRECT_PATH=/auth/callback
NLM_MCP_OAUTH_REQUIRED_SCOPES=read:user,user:email
NLM_MCP_OAUTH_ALLOWED_USERS=

# --- NotebookLM backend ---
NLM_MCP_NOTEBOOKLM_AUTH_JSON=
NLM_MCP_NOTEBOOKLM_AUTH_FILE=~/.config/nlm-mcp/notebooklm_auth.json
NLM_MCP_DEFAULT_LANGUAGE=en

# --- Storage ---
NLM_MCP_DATA_DIR=~/.local/share/nlm-mcp
NLM_MCP_SESSION_DB=sqlite+aiosqlite:///{DATA_DIR}/sessions.db
NLM_MCP_ENCRYPTION_KEY=
NLM_MCP_REDIS_URL=

# --- Rate limiting ---
NLM_MCP_RATE_LIMIT_ENABLED=true
NLM_MCP_RATE_LIMIT_PER_USER_RPM=60
NLM_MCP_RATE_LIMIT_GENERATE_RPM=10

# --- Observability ---
NLM_MCP_LOG_LEVEL=INFO
NLM_MCP_LOG_FORMAT=json
NLM_MCP_AUDIT_LOG_PATH={DATA_DIR}/audit.log

# --- Behavior ---
NLM_MCP_DESTRUCTIVE_REQUIRES_CONFIRM=true
NLM_MCP_DEFAULT_POLL_INTERVAL_SEC=15
NLM_MCP_DEFAULT_POLL_TIMEOUT_SEC=600
